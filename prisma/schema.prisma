generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model brands {
  id         Int        @id @default(autoincrement())
  name       String     @db.NVarChar(255) @map("ten")
  logo       String?    @db.NVarChar(255)
  country    String?    @db.NVarChar(100) @map("quoc_gia")
  created_at DateTime?  @default(now()) @db.DateTime @map("ngay_tao")
  products   products[]

  @@map("thuong_hieu")
}

model categories {
  id               Int          @id @default(autoincrement())
  name             String       @db.NVarChar(255) @map("ten")
  parent_id        Int?         @map("danh_muc_cha_id")
  slug             String?      @unique @db.NVarChar(255)
  created_at       DateTime?    @default(now()) @db.DateTime @map("ngay_tao")
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]

  @@map("danh_muc")
}

model product_reviews {
  id         Int       @id @default(autoincrement())
  product_id Int?      @map("san_pham_id")
  rating     Int?      @map("diem_danh_gia")
  comment    String?   @db.NVarChar(Max) @map("binh_luan")
  created_at DateTime? @default(now()) @db.DateTime @map("ngay_tao")
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("danh_gia_san_pham")
}

model products {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.NVarChar(255) @map("ten")
  slug               String?              @unique @db.NVarChar(255)
  description        String?              @db.NVarChar(Max) @map("mo_ta")
  brand_id           Int?                 @map("thuong_hieu_id")
  category_id        Int?                 @map("danh_muc_id")
  price              Decimal              @db.Decimal(12, 2) @map("gia")
  stock              Int?                 @default(0) @map("ton_kho")
  image_url          String?              @db.NVarChar(255) @map("url_anh")
  image_url_2        String?              @db.NVarChar(255) @map("url_anh_2")
  status             String?              @default("active") @db.NVarChar(20) @map("trang_thai")
  created_at         DateTime?            @default(now()) @db.DateTime @map("ngay_tao")
  product_reviews    product_reviews[]
  brands             brands?              @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories         categories?          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cart_items         cart_items[]
  order_items        order_items[]

  @@index([name], map: "idx_product_name")
  @@index([price], map: "idx_product_price")
  @@map("san_pham")
}

model users {
  id         Int          @id @default(autoincrement())
  email      String       @unique @db.NVarChar(255)
  password   String       @db.NVarChar(255) @map("mat_khau")
  role       String       @default("USER") @db.NVarChar(50) @map("vai_tro")
  name       String?      @db.NVarChar(255) @map("ten")
  phone      String?      @db.NVarChar(20) @map("so_dien_thoai")
  address    String?      @db.NVarChar(500) @map("dia_chi")
  created_at DateTime?    @default(now()) @db.DateTime @map("ngay_tao")
  cart_items cart_items[]
  orders     orders[]

  @@map("nguoi_dung")
}

model cart_items {
  id         Int       @id @default(autoincrement())
  user_id    Int       @map("nguoi_dung_id")
  product_id Int       @map("san_pham_id")
  quantity   Int       @default(1) @map("so_luong")
  created_at DateTime? @default(now()) @db.DateTime @map("ngay_tao")
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@map("chi_tiet_gio_hang")
}

model orders {
  id           Int           @id @default(autoincrement())
  user_id      Int           @map("nguoi_dung_id")
  total_amount Float         @map("tong_tien")
  status       String        @default("PENDING") @db.NVarChar(50) @map("trang_thai")
  created_at   DateTime?     @default(now()) @db.DateTime @map("ngay_tao")
  order_items  order_items[]
  users        users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("don_hang")
}

model order_items {
  id         Int      @id @default(autoincrement())
  order_id   Int      @map("don_hang_id")
  product_id Int      @map("san_pham_id")
  quantity   Int      @map("so_luong")
  price      Float    @map("gia")
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("chi_tiet_don_hang")
}
